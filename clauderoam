#!/usr/bin/env bash
# clauderoam — Your Claude Code config, anywhere.
#
# One-tool CLI for setting up, syncing, and checking your portable
# Claude Code configuration.
#
# Run `clauderoam help` for usage.

set -euo pipefail

# ── Constants ────────────────────────────────────────────────────────────────

readonly VERSION="0.4.1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly CLAUDE_DIR="${CLAUDE_HOME:-$HOME/.claude}"

# DATA_DIR — where the user's config repo lives.
#   Priority: $CLAUDEROAM_DATA env var → git checkout next to script → ~/clauderoam
_resolve_data_dir() {
  if [ -n "${CLAUDEROAM_DATA:-}" ]; then
    printf '%s' "$CLAUDEROAM_DATA"
  elif [ -f "$SCRIPT_DIR/CLAUDE.md" ] && [ -d "$SCRIPT_DIR/.git" ]; then
    printf '%s' "$SCRIPT_DIR"
  else
    printf '%s' "$HOME/clauderoam"
  fi
}
DATA_DIR="$(_resolve_data_dir)"
readonly DATA_DIR

# STARTER_DIR — where template files live (for seeding a new DATA_DIR).
#   Checks: alongside the script (git checkout) → Homebrew share dir → /usr/local/share
_resolve_starter_dir() {
  for candidate in \
    "$SCRIPT_DIR" \
    "$SCRIPT_DIR/../share/clauderoam" \
    "/opt/homebrew/share/clauderoam" \
    "/usr/local/share/clauderoam"; do
    if [ -f "$candidate/CLAUDE.md" ] && [ "$candidate" != "$DATA_DIR" ]; then
      ( cd "$candidate" && pwd )
      return
    fi
  done
  # Fallback: if script dir IS the data dir (git checkout), starters == data
  if [ -f "$SCRIPT_DIR/CLAUDE.md" ]; then
    printf '%s' "$SCRIPT_DIR"
  fi
}
STARTER_DIR="$(_resolve_starter_dir)"
readonly STARTER_DIR

# Items to symlink from repo → ~/.claude/
readonly LINK_ITEMS=(
  "CLAUDE.md"
  "settings.json"
  "agents"
  "skills"
  "commands"
  "keybindings.json"
)

# Items that MUST stay machine-local (never overwrite from repo)
readonly PRESERVE_ITEMS=(
  ".credentials.json"
  "policy-limits.json"
  "telemetry"
  "sessions"
  "shell-snapshots"
  "session-env"
  "projects"
  "backups"
  "plans"
  "todos"
  "statsig"
  ".last-cleanup"
  "settings.local.json"
  "CLAUDE.local.md"
)

# ── Pretty output ────────────────────────────────────────────────────────────

if [ -t 1 ] && [ "${NO_COLOR:-}" = "" ]; then
  C_DIM='\033[2m';  C_BOLD='\033[1m'
  C_RED='\033[31m'; C_GRN='\033[32m'; C_YEL='\033[33m'; C_BLU='\033[34m'
  C_RST='\033[0m'
else
  C_DIM=''; C_BOLD=''; C_RED=''; C_GRN=''; C_YEL=''; C_BLU=''; C_RST=''
fi

say()  { printf '%b\n' "$*"; }
info() { printf '%b\n' "${C_DIM}  $*${C_RST}"; }
ok()   { printf '%b\n' "${C_GRN}  ✓${C_RST} $*"; }
warn() { printf '%b\n' "${C_YEL}  !${C_RST} $*" >&2; }
err()  { printf '%b\n' "${C_RED}  ✗${C_RST} $*" >&2; }
step() { printf '\n%b\n' "${C_BOLD}${C_BLU}▸${C_RST} ${C_BOLD}$*${C_RST}"; }

ask() {
  local prompt="$1" default="${2:-}" answer
  # Prompt goes to stderr so $(ask ...) only captures the answer
  if [ -n "$default" ]; then
    printf '%b' "  ${C_BOLD}?${C_RST} $prompt ${C_DIM}[$default]${C_RST}: " >&2
  else
    printf '%b' "  ${C_BOLD}?${C_RST} $prompt: " >&2
  fi
  read -r answer
  printf '%s' "${answer:-$default}"
}

# ── Subcommand: help ─────────────────────────────────────────────────────────

cmd_help() {
  cat <<EOF
${C_BOLD}clauderoam${C_RST} — Your Claude Code config, anywhere. (v$VERSION)

${C_BOLD}USAGE${C_RST}
  clauderoam <command> [flags]

${C_BOLD}COMMANDS${C_RST}
  ${C_GRN}init${C_RST}       Interactive first-time setup (personalize + install)
  ${C_GRN}install${C_RST}    Symlink this repo's portable items into ~/.claude/
  ${C_GRN}doctor${C_RST}     Check that everything is wired up and safe
  ${C_GRN}sync${C_RST}       Snapshot ~/.claude/projects/*/memory/ into ./memory/
  ${C_GRN}restore${C_RST}    Restore memory from ./memory/ to ~/.claude/projects/
  ${C_GRN}push${C_RST}       sync + git commit + git push (one-shot)
  ${C_GRN}status${C_RST}     Show repo + symlink state
  ${C_GRN}projects${C_RST}   Manage your project registry (clone-all, pull-all, …)
  ${C_GRN}help${C_RST}       This message
  ${C_GRN}version${C_RST}    Print version

${C_BOLD}FLAGS${C_RST}
  --dry-run    Print actions without changing anything (install/sync/restore)
  --no-color   Disable ANSI colors (or set NO_COLOR=1)

${C_BOLD}ENVIRONMENT${C_RST}
  CLAUDEROAM_DATA   Path to your config repo (default: ~/clauderoam)
  CLAUDE_HOME       Path Claude Code reads from (default: ~/.claude)
  NO_COLOR          Disable ANSI colors when set

${C_BOLD}EXAMPLES${C_RST}
  clauderoam init                Personalize and install in one go
  clauderoam doctor              Verify your setup is healthy
  clauderoam push                Snapshot memory and push to GitHub

Docs: https://github.com/YunyueLi/clauderoam
EOF
}

cmd_version() { say "clauderoam $VERSION"; }

# ── Subcommand: init ─────────────────────────────────────────────────────────

cmd_init() {
  step "Welcome to clauderoam"
  info "Data directory: $DATA_DIR"
  echo

  # Step 1: seed DATA_DIR with starter files if it's new
  local seeded=0
  if [ ! -d "$DATA_DIR" ] || [ -z "$(ls -A "$DATA_DIR" 2>/dev/null)" ]; then
    if [ -z "$STARTER_DIR" ]; then
      err "Starter files not found. Reinstall clauderoam or set CLAUDEROAM_DATA."
      exit 1
    fi
    step "Seeding new data directory from $STARTER_DIR"
    mkdir -p "$DATA_DIR"
    # Copy template content (everything except git internals and runtime cruft)
    ( cd "$STARTER_DIR" && find . -maxdepth 1 -mindepth 1 \
        ! -name '.git' ! -name '.github' ! -name 'memory' \
        ! -name 'clauderoam' ! -name 'docs' \
        -exec cp -R {} "$DATA_DIR/" \; )
    # Create an empty memory dir
    mkdir -p "$DATA_DIR/memory"
    ok "Copied starter files"
    seeded=1
  fi

  # Step 2: initialize git if needed
  if [ ! -d "$DATA_DIR/.git" ]; then
    step "Initializing git repository"
    ( cd "$DATA_DIR" && git init -q -b main )
    ok "git init"
  fi

  # Step 3: interactive personalization
  local default_name default_lang=en
  default_name="$(git config --global user.name 2>/dev/null || echo "")"
  default_name="${default_name:-$USER}"
  if locale 2>/dev/null | grep -qi 'zh_CN\|zh_TW'; then default_lang=zh; fi

  step "Personalize your CLAUDE.md"
  local name lang
  name="$(ask "Your name (shows up in CLAUDE.md)" "$default_name")"
  lang="$(ask "Preferred language for Claude to respond in (en/zh/ja/...)" "$default_lang")"
  _render_claude_md "$name" "$lang"
  ok "Wrote $DATA_DIR/CLAUDE.md"

  # Step 4: install symlinks into ~/.claude/
  step "Linking $DATA_DIR → $CLAUDE_DIR"
  cmd_install
  echo

  # Step 5: next steps
  step "Next steps"
  if [ "$seeded" = 1 ]; then
    info "1. Push your new config repo to GitHub so other devices can pull it:"
    info "     cd $DATA_DIR"
    info "     gh repo create clauderoam --private --source=. --remote=origin --push"
    info "   (or do it manually via the GitHub UI + git push)"
    info "2. Restart Claude Code to pick up the new config"
    info "3. On a second device:"
    info "     brew install YunyueLi/tap/clauderoam"
    info "     git clone <your repo> ~/clauderoam"
    info "     clauderoam install"
  else
    info "1. Restart Claude Code to pick up the new config"
    info "2. Commit your changes:  cd $DATA_DIR && git add CLAUDE.md && git commit -m 'chore: personalize' && git push"
  fi
}

_render_claude_md() {
  local name="$1" lang="$2"
  cat > "$DATA_DIR/CLAUDE.md" <<EOF
# My Claude Code Preferences

> Loaded by Claude Code on every session start (via \`~/.claude/CLAUDE.md\` symlink).
> Edit freely. Commit and push to sync across all your devices.

## About me

- Name: $name
- Preferred response language: $lang

## Communication

- Be concise; prefer lists and tables over long paragraphs
- State assumptions; say "I don't know" when uncertain
- Skip the trailing "summary" — the diff is the summary
- No emojis unless I ask

## Engineering defaults

- Conventional commits (\`feat:\`, \`fix:\`, \`chore:\`, …)
- Confirm before destructive ops (\`rm -rf\`, force push, \`reset --hard\`)
- For new projects: scaffold \`CLAUDE.md\` + \`.claude/settings.json\` first
- Don't add comments that just restate the code

## Memory rules

- Save: durable preferences, corrections you've given me, lessons across sessions
- Skip: ephemeral task state; anything in project \`CLAUDE.md\` or git history;
  account-specific info (subscription, billing)
EOF
}

# ── Subcommand: install ──────────────────────────────────────────────────────

cmd_install() {
  local dry_run=0
  for arg in "$@"; do
    case "$arg" in --dry-run|-n) dry_run=1 ;; esac
  done

  if [ "$DATA_DIR" = "$CLAUDE_DIR" ]; then
    err "Repo and target are the same path. Move the repo elsewhere."; exit 1
  fi

  _run() {
    if [ "$dry_run" = 1 ]; then info "[dry-run] $*"
    else "$@"; fi
  }

  # Backup existing config
  local backup=""
  if [ -d "$CLAUDE_DIR" ] && [ -n "$(ls -A "$CLAUDE_DIR" 2>/dev/null)" ]; then
    backup="$HOME/.claude.bak.$(date +%Y%m%d-%H%M%S)"
    info "Backing up existing config → $backup"
    _run cp -R "$CLAUDE_DIR" "$backup"
  fi
  _run mkdir -p "$CLAUDE_DIR"

  # Restore preserved items
  if [ -n "$backup" ]; then
    for item in "${PRESERVE_ITEMS[@]}"; do
      if [ -e "$backup/$item" ] && [ ! -e "$CLAUDE_DIR/$item" ]; then
        _run cp -R "$backup/$item" "$CLAUDE_DIR/$item"
      fi
    done
  fi

  # Create symlinks
  local linked=0
  for item in "${LINK_ITEMS[@]}"; do
    local src="$DATA_DIR/$item" dst="$CLAUDE_DIR/$item"
    [ -e "$src" ] || continue
    [ -L "$dst" ] || [ -e "$dst" ] && _run rm -rf "$dst"
    _run ln -s "$src" "$dst"
    ok "$item"
    linked=$((linked + 1))
  done

  echo
  ok "Linked $linked items into $CLAUDE_DIR"
  if [ -n "$backup" ]; then
    info "Backup at: $backup (delete once you've verified things work)"
  fi
  return 0
}

# ── Subcommand: doctor ───────────────────────────────────────────────────────

cmd_doctor() {
  local pass=0 fail=0 warn=0

  step "Environment"
  for tool in git rsync; do
    if command -v "$tool" >/dev/null 2>&1; then ok "$tool installed"; pass=$((pass+1))
    else err "$tool not installed"; fail=$((fail+1)); fi
  done
  if command -v gh >/dev/null 2>&1; then ok "gh (optional) installed"; pass=$((pass+1))
  else warn "gh not installed (optional, useful for repo ops)"; warn=$((warn+1)); fi

  step "Symlinks"
  for item in "${LINK_ITEMS[@]}"; do
    local src="$DATA_DIR/$item" dst="$CLAUDE_DIR/$item"
    [ -e "$src" ] || { info "$item: not in repo (skipping)"; continue; }
    if [ ! -L "$dst" ]; then
      err "$item: missing or not a symlink"; fail=$((fail+1))
    elif [ "$(readlink "$dst")" = "$src" ]; then
      ok "$item → $src"; pass=$((pass+1))
    else
      err "$item points to $(readlink "$dst") (expected $src)"; fail=$((fail+1))
    fi
  done

  step "Safety: no secrets in repo"
  for item in .credentials.json policy-limits.json sessions shell-snapshots; do
    if [ -e "$DATA_DIR/$item" ]; then err "$item is inside the repo!"; fail=$((fail+1))
    else ok "$item not in repo"; pass=$((pass+1)); fi
  done
  if [ -d "$DATA_DIR/.git" ]; then
    local tracked
    tracked="$(cd "$DATA_DIR" && git ls-files | grep -E '\.credentials\.json|policy-limits\.json|sessions/|shell-snapshots/' || true)"
    if [ -n "$tracked" ]; then err "Sensitive paths are tracked in git!"; printf '%s\n' "$tracked" | sed 's/^/      /'; fail=$((fail+1))
    else ok "Nothing sensitive is tracked in git"; pass=$((pass+1)); fi
  fi

  echo
  if [ "$fail" -gt 0 ]; then
    say "${C_RED}✗${C_RST} $pass passed, ${C_RED}$fail failed${C_RST}, $warn warning(s) — run ${C_BOLD}clauderoam install${C_RST} to fix link issues"
    exit 1
  else
    say "${C_GRN}✓${C_RST} Healthy ($pass passed, $warn warning(s))"
  fi
}

# ── Subcommand: sync ─────────────────────────────────────────────────────────

cmd_sync() {
  local src="$CLAUDE_DIR/projects" dst="$DATA_DIR/memory"
  if [ ! -d "$src" ]; then info "No $src found — nothing to sync"; return 0; fi
  mkdir -p "$dst"
  local count=0
  for proj in "$src"/*/; do
    [ -d "$proj/memory" ] && [ -n "$(ls -A "$proj/memory" 2>/dev/null)" ] || continue
    local name; name="$(basename "$proj")"
    mkdir -p "$dst/$name"
    rsync -a --delete "$proj/memory/" "$dst/$name/"
    ok "$name"
    count=$((count + 1))
  done
  echo
  if [ "$count" -eq 0 ]; then info "No memory to sync"
  else ok "Synced $count project(s) → memory/"
       info "Next: git add memory && git commit && git push  (or use 'clauderoam push')"
  fi
}

# ── Subcommand: restore ──────────────────────────────────────────────────────

cmd_restore() {
  local src="$DATA_DIR/memory" dst="$CLAUDE_DIR/projects"
  if [ ! -d "$src" ] || [ -z "$(ls -A "$src" 2>/dev/null)" ]; then
    info "No memory snapshots in repo — nothing to restore"; return 0
  fi
  mkdir -p "$dst"
  local prefix="-Users-$USER" restored=0
  for proj in "$src"/*/; do
    [ -d "$proj" ] || continue
    local name; name="$(basename "$proj")"
    case "$name" in README.md|memory) continue ;; esac
    [[ "$name" == -* ]] || continue
    local new_name
    if [[ "$name" == "$prefix"* ]]; then new_name="$name"
    elif [[ "$name" == -Users-* ]]; then
      local suffix="${name#-Users-}"; suffix="${suffix#*-}"
      new_name="$prefix-$suffix"
      info "rewrote $name → $new_name"
    else warn "skip $name (unknown format)"; continue
    fi
    mkdir -p "$dst/$new_name/memory"
    rsync -a "$proj/" "$dst/$new_name/memory/"
    ok "$new_name"
    restored=$((restored + 1))
  done
  echo
  ok "Restored $restored project(s)"
}

# ── Subcommand: push ─────────────────────────────────────────────────────────

cmd_push() {
  step "Snapshot memory"
  cmd_sync
  echo
  step "Push to GitHub"
  ( cd "$DATA_DIR"
    if [ ! -d .git ]; then err "Not a git repo"; exit 1; fi
    git add -A
    if git diff --cached --quiet; then info "Nothing to commit"
    else git commit -m "chore: sync $(date +%Y-%m-%d_%H:%M)" && ok "Committed"
    fi
    git push && ok "Pushed"
  )
}

# ── Subcommand: status ───────────────────────────────────────────────────────

cmd_status() {
  step "Repo: $DATA_DIR"
  ( cd "$DATA_DIR" && git status --short 2>/dev/null || say "  (not a git repo)" )
  step "Symlinks in $CLAUDE_DIR"
  local found=0
  for item in "${LINK_ITEMS[@]}"; do
    if [ -L "$CLAUDE_DIR/$item" ]; then
      printf '  %b%s%b → %s\n' "$C_GRN" "$item" "$C_RST" "$(readlink "$CLAUDE_DIR/$item")"
      found=1
    fi
  done
  if [ "$found" = 0 ]; then
    say "  ${C_DIM}(no symlinks — run 'clauderoam install')${C_RST}"
  fi
  return 0
}

# ── Subcommand: projects ─────────────────────────────────────────────────────
#
# Tracks a list of project repos the user wants on every machine. The list is
# kept at $DATA_DIR/projects.tsv (one tab-separated row per project) so it
# syncs through the same git repo as the rest of the personal config.

PROJECTS_FILE="$DATA_DIR/projects.tsv"

# Print non-comment, non-empty lines
_projects_entries() {
  [ -f "$PROJECTS_FILE" ] || return 0
  grep -vE '^[[:space:]]*(#|$)' "$PROJECTS_FILE" || true
}

# Expand a leading ~ in a path. We match literal ~ on purpose.
# shellcheck disable=SC2088
_expand_path() {
  case "$1" in
    "~/"*) printf '%s/%s' "$HOME" "${1#~/}" ;;
    "~")   printf '%s' "$HOME" ;;
    *)     printf '%s' "$1" ;;
  esac
}

_projects_init_file() {
  if [ ! -f "$PROJECTS_FILE" ]; then
    cat > "$PROJECTS_FILE" <<'EOF'
# clauderoam projects registry
# One project per line, tab-separated:
#   name<TAB>repo-url<TAB>local-path
# Lines starting with # are comments.
EOF
  fi
}

cmd_projects() {
  local sub="${1:-list}"
  shift || true
  case "$sub" in
    list)           cmd_projects_list ;;
    add)            cmd_projects_add ;;
    remove|rm)      cmd_projects_remove "$@" ;;
    clone-all)      cmd_projects_clone_all "$@" ;;
    pull-all)       cmd_projects_pull_all "$@" ;;
    status)         cmd_projects_status ;;
    help|-h|--help) cmd_projects_help ;;
    *) err "Unknown projects subcommand: $sub"; cmd_projects_help; exit 2 ;;
  esac
}

cmd_projects_help() {
  cat <<EOF
${C_BOLD}clauderoam projects${C_RST} — manage your project registry

${C_BOLD}USAGE${C_RST}
  clauderoam projects <subcommand>

${C_BOLD}SUBCOMMANDS${C_RST}
  ${C_GRN}list${C_RST}        List registered projects (default if omitted)
  ${C_GRN}add${C_RST}         Interactively register a project
  ${C_GRN}remove${C_RST}      Remove a project from the registry (files NOT deleted)
  ${C_GRN}clone-all${C_RST}   Clone all registered projects (skips existing paths)
  ${C_GRN}pull-all${C_RST}    git pull each project (skips dirty trees)
  ${C_GRN}status${C_RST}      Show git status of each project

Registry file: $PROJECTS_FILE
EOF
}

cmd_projects_list() {
  if [ ! -s "$PROJECTS_FILE" ] || [ -z "$(_projects_entries)" ]; then
    info "No projects registered."
    info "Add one with: clauderoam projects add"
    return 0
  fi
  printf '  %-22s %-50s %s\n' "NAME" "REPO" "PATH"
  printf '  %-22s %-50s %s\n' "────" "────" "────"
  while IFS=$'\t' read -r name repo path; do
    printf '  %-22s %-50s %s\n' "$name" "$repo" "$path"
  done < <(_projects_entries)
}

cmd_projects_add() {
  _projects_init_file
  step "Register a new project"

  local name repo path
  name="$(ask "Short name (used for display)" "")"
  if [ -z "$name" ]; then err "Name required"; exit 2; fi
  if ! printf '%s' "$name" | grep -qE '^[A-Za-z0-9_-]+$'; then
    err "Name must be [A-Za-z0-9_-]+ (no spaces or special chars)"; exit 2
  fi
  if grep -qE "^${name}"$'\t' "$PROJECTS_FILE" 2>/dev/null; then
    err "A project named '$name' is already registered"; exit 1
  fi

  repo="$(ask "Repo URL (git@... or https://...)" "")"
  if [ -z "$repo" ]; then err "Repo URL required"; exit 2; fi

  # We store the literal "~/..." so the registry is portable across users.
  # _expand_path handles real-time expansion when we actually use it.
  # shellcheck disable=SC2088
  local default_path="~/Desktop/$name"
  path="$(ask "Local path" "$default_path")"

  printf '%s\t%s\t%s\n' "$name" "$repo" "$path" >> "$PROJECTS_FILE"
  ok "Registered $name → $path"
  echo
  info "Commit so other devices see it:"
  info "  cd $DATA_DIR && git add projects.tsv && git commit -m 'add project: $name' && git push"
}

cmd_projects_remove() {
  local target="${1:-}"
  [ -n "$target" ] || { err "Usage: clauderoam projects remove <name>"; exit 2; }
  [ -f "$PROJECTS_FILE" ] || { err "No registry yet"; exit 1; }
  if ! grep -qE "^${target}"$'\t' "$PROJECTS_FILE"; then
    err "No project named '$target'"; exit 1
  fi
  local tmp; tmp="$(mktemp)"
  grep -vE "^${target}"$'\t' "$PROJECTS_FILE" > "$tmp"
  mv "$tmp" "$PROJECTS_FILE"
  ok "Removed '$target' from registry (local files NOT deleted)"
}

cmd_projects_clone_all() {
  local dry_run=0
  for arg in "$@"; do
    case "$arg" in --dry-run|-n) dry_run=1 ;; esac
  done

  if [ ! -s "$PROJECTS_FILE" ] || [ -z "$(_projects_entries)" ]; then
    info "No projects to clone"; return 0
  fi

  step "Cloning registered projects"
  local cloned=0 skipped=0 failed=0
  while IFS=$'\t' read -r name repo path; do
    local expanded
    expanded="$(_expand_path "$path")"
    if [ -d "$expanded/.git" ]; then
      info "skip $name (already at $expanded)"
      skipped=$((skipped + 1))
      continue
    fi
    if [ -d "$expanded" ] && [ -n "$(ls -A "$expanded" 2>/dev/null)" ]; then
      warn "skip $name ($expanded exists and is not a git repo)"
      skipped=$((skipped + 1))
      continue
    fi
    if [ "$dry_run" = 1 ]; then
      info "[dry-run] git clone $repo $expanded"
      continue
    fi
    mkdir -p "$(dirname "$expanded")"
    if git clone --quiet "$repo" "$expanded" 2>&1; then
      ok "cloned $name → $expanded"
      cloned=$((cloned + 1))
    else
      err "failed to clone $name"
      failed=$((failed + 1))
    fi
  done < <(_projects_entries)
  echo
  ok "cloned $cloned, skipped $skipped, failed $failed"
}

cmd_projects_pull_all() {
  if [ ! -s "$PROJECTS_FILE" ] || [ -z "$(_projects_entries)" ]; then
    info "No projects"; return 0
  fi
  step "Pulling registered projects"
  local pulled=0 skipped=0
  while IFS=$'\t' read -r name repo path; do
    local expanded
    expanded="$(_expand_path "$path")"
    if [ ! -d "$expanded/.git" ]; then
      info "skip $name (not cloned)"
      skipped=$((skipped + 1))
      continue
    fi
    if [ -n "$(cd "$expanded" && git status --porcelain 2>/dev/null)" ]; then
      warn "skip $name (uncommitted changes)"
      skipped=$((skipped + 1))
      continue
    fi
    if (cd "$expanded" && git pull --ff-only --quiet 2>/dev/null); then
      ok "$name pulled"
      pulled=$((pulled + 1))
    else
      warn "skip $name (pull failed — non-fast-forward?)"
      skipped=$((skipped + 1))
    fi
  done < <(_projects_entries)
  echo
  ok "pulled $pulled, skipped $skipped"
}

cmd_projects_status() {
  if [ ! -s "$PROJECTS_FILE" ] || [ -z "$(_projects_entries)" ]; then
    info "No projects"; return 0
  fi
  step "Project status"
  while IFS=$'\t' read -r name repo path; do
    local expanded
    expanded="$(_expand_path "$path")"
    if [ ! -d "$expanded/.git" ]; then
      printf '  %s○%s %-22s missing (%s)\n' "$C_YEL" "$C_RST" "$name" "$expanded"
      continue
    fi
    local dirty branch ahead
    dirty="$(cd "$expanded" && git status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
    branch="$(cd "$expanded" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
    ahead="$(cd "$expanded" && git rev-list '@{u}..HEAD' --count 2>/dev/null || echo 0)"
    if [ "$dirty" -gt 0 ]; then
      printf '  %s●%s %-22s %s • %s file(s) changed\n' "$C_YEL" "$C_RST" "$name" "$branch" "$dirty"
    elif [ "$ahead" -gt 0 ]; then
      printf '  %s↑%s %-22s %s • %s commit(s) to push\n' "$C_YEL" "$C_RST" "$name" "$branch" "$ahead"
    else
      printf '  %s✓%s %-22s %s • clean\n' "$C_GRN" "$C_RST" "$name" "$branch"
    fi
  done < <(_projects_entries)
  return 0
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    init)              cmd_init "$@" ;;
    install|bootstrap) cmd_install "$@" ;;
    doctor)            cmd_doctor "$@" ;;
    sync)              cmd_sync "$@" ;;
    restore)           cmd_restore "$@" ;;
    push)              cmd_push "$@" ;;
    status)            cmd_status "$@" ;;
    projects)          cmd_projects "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|"")    cmd_help ;;
    *) err "Unknown command: $cmd"; say ""; cmd_help; exit 2 ;;
  esac
}

main "$@"
